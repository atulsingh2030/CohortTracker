PORT=3001
GITHUB_TOKEN=
GITHUB_REPOSITORIES=owner-one/repo-one,owner-two/repo-two
CONTRIBUTION_SYNC_CRON=0 6 * * *
CONTRIBUTION_SYNC_TIMEZONE=UTC
CONTRIBUTION_LOOKBACK_DAYS=56
# Leave blank to keep the browser "Run sync now" button enabled.
# Set a value to require the X-Sync-Secret header for manual sync requests.
CONTRIBUTION_SYNC_SECRET=
# Frontend origins allowed to call the Express API.
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app
# When the frontend is deployed separately on Vercel, point this to the backend host.
VITE_API_BASE_URL=http://localhost:3001
# Optional frontend mode:
# api    -> use live Express endpoints
# static -> use committed snapshot JSON files
VITE_CONTRIBUTION_DATA_MODE=api
VITE_CONTRIBUTION_SNAPSHOT_BASE_URL=/contribution-data/latest
